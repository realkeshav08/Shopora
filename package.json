{
  "name": "shopora-monorepo",
  "version": "1.0.0",
  "description": "Shopora E-Commerce Monorepo",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && npm run server",
    "dev:frontend": "cd frontend && npm run dev -- --force",
    "dev:admin": "cd admin && npm run dev -- --force",
    "dev:reco": "cd recommendation-service && venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --port 8000",
    "dev": "npx concurrently -n backend,frontend,admin,reco \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:admin\" \"npm run dev:reco\"",
    "build:frontend": "cd frontend && npm run build",
    "build:admin": "cd admin && npm run build",
    "build": "npm run build:frontend && npm run build:admin"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
