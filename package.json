{
  "name": "shopora-monorepo",
  "version": "1.0.0",
  "description": "Shopora E-Commerce Monorepo",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && npm run server",
    "dev:frontend": "cd frontend && npm run dev -- --force",
    "dev:admin": "cd admin && npm run dev -- --force",
    "dev": "npx concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:admin\"",
    "build:frontend": "cd frontend && npm run build",
    "build:admin": "cd admin && npm run build",
    "build": "npm run build:frontend && npm run build:admin"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
